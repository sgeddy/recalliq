{
  "name": "@recalliq/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "db:seed": "dotenv -e .env -- tsx seeds/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/pg": "^8.11.5",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0"
  }
}
