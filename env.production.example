# Database password (used by docker-compose for Postgres container + connection string)
DB_PASSWORD=changeme

# Clerk auth
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Access code gate — SHA-256 hex hash of the signup access code
# Generate with: echo -n "your-secret-code" | shasum -a 256 | cut -d' ' -f1
ACCESS_CODE_HASH=

# Clerk webhook secret (from Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=

# Signup allowlist — comma-separated emails allowed to register
# Leave empty to allow all signups (open mode)
ALLOWED_SIGNUP_EMAILS=

# Anthropic (for AI course generation)
ANTHROPIC_API_KEY=

# Twilio (for voice/SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ElevenLabs (for voice TTS)
ELEVENLABS_VOICE_ID=

# Resend (for email)
RESEND_API_KEY=

# App URLs
NEXT_PUBLIC_API_URL=https://study.samueleddy.com/api
WEB_BASE_URL=https://study.samueleddy.com
API_BASE_URL=https://study.samueleddy.com/api
ALLOWED_ORIGINS=https://study.samueleddy.com
